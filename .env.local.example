# Copy this file to .env.local and fill in your Supabase project's values.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: your production domain, used to build the QR codes on the admin page.
# Falls back to the request's own host when unset (fine for local dev / preview URLs).
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
