# Copy this file to .env.local and fill in your Supabase project's values.
#
# Project URL:      Project Settings → Integrations → Data API (NOT the API Keys page)
# Publishable key:  Project Settings → API Keys → "publishable" key (starts with sb_publishable_)
#
# NEVER put the "secret" key (sb_secret_...) here or in any NEXT_PUBLIC_ variable —
# it bypasses Row Level Security and would ship straight into the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key

# Optional: your production domain, used to build the QR codes on the admin page.
# Falls back to the request's own host when unset (fine for local dev / preview URLs).
NEXT_PUBLIC_SITE_URL=https://tramkyuc-eta.vercel.app
